# Python
__pycache__/
*.py[cod]
.venv/
.python-version-cache
*.egg-info/

# Data — too large for git
data/audio/*.mp3
data/audio/*.wav
data/audio/*.ogg
data/audio/*.m4a
data/audio/*.flac
data/refs/*.jpg
data/refs/*.jpeg
data/refs/*.png
data/outputs/*.png
data/outputs/*.jpg

# Keep folder structure
!data/audio/.gitkeep
!data/refs/.gitkeep
!data/outputs/.gitkeep

# Models cache
.cache/
*.bin
*.safetensors

# IDE
.vscode/
.idea/
.DS_Store

# Paper drafts — kept locally, never tracked (private until publication)
docs/*.docx
docs/*.doc
docs/*.htm
docs/*.html
docs/*.pdf

# Local-only build sources containing full paper text (not for public repo)
notebooks/v4_revisions.ps1
notebooks/v4_leonardo_overlay.ps1
notebooks/v3_en_text.txt
notebooks/v3_ko_text.txt

# Local server config
.claude/
